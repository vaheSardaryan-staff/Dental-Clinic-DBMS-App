<div>
  <div class="mb-6">
    <a href="/patients" class="text-sm text-blue-600 hover:underline">&larr; Back to Patients</a>
    <h1 class="text-2xl font-bold text-gray-800 mt-2"><%= patient ? (patient.first_name + ' ' + patient.last_name) : 'Patient Not Found' %></h1>
    <p class="text-sm text-gray-500 mt-1">Data from <span class="sql-badge badge-procedure">STORED PROCEDURE</span> sp_GetPatientSummary (4 result sets)</p>
  </div>

  <% if (patient) { %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    <!-- Patient Info -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
      <h3 class="text-lg font-semibold text-gray-800 mb-4">Demographics</h3>
      <dl class="space-y-3 text-sm">
        <div><dt class="text-gray-500">Phone</dt><dd class="font-medium"><%= patient.phone || '-' %></dd></div>
        <div><dt class="text-gray-500">Email</dt><dd class="font-medium"><%= patient.email || '-' %></dd></div>
        <div><dt class="text-gray-500">Date of Birth</dt><dd class="font-medium"><%= patient.date_of_birth ? new Date(patient.date_of_birth).toLocaleDateString() : '-' %></dd></div>
        <div><dt class="text-gray-500">Gender</dt><dd class="font-medium capitalize"><%= patient.gender || '-' %></dd></div>
        <div><dt class="text-gray-500">Dentist</dt><dd class="font-medium"><%= patient.dentist_name || patient.full_name || '-' %></dd></div>
      </dl>
    </div>

    <!-- Visit Stats -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
      <h3 class="text-lg font-semibold text-gray-800 mb-4">Visit Statistics</h3>
      <% if (visitStats) { %>
      <dl class="space-y-3 text-sm">
        <div><dt class="text-gray-500">Total Visits</dt><dd class="text-2xl font-bold text-blue-600"><%= visitStats.total_visits || 0 %></dd></div>
        <div><dt class="text-gray-500">First Visit</dt><dd class="font-medium"><%= visitStats.first_visit ? new Date(visitStats.first_visit).toLocaleDateString() : '-' %></dd></div>
        <div><dt class="text-gray-500">Last Visit</dt><dd class="font-medium"><%= visitStats.last_visit ? new Date(visitStats.last_visit).toLocaleDateString() : '-' %></dd></div>
      </dl>
      <% } else { %><p class="text-gray-400 text-sm">No visit data</p><% } %>
    </div>

    <!-- Financial -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
      <h3 class="text-lg font-semibold text-gray-800 mb-4">Financial Summary</h3>
      <% if (financial) { %>
      <dl class="space-y-3 text-sm">
        <div><dt class="text-gray-500">Total Billed</dt><dd class="text-xl font-bold text-gray-800">$<%= Number(financial.total_billed || 0).toFixed(2) %></dd></div>
        <div><dt class="text-gray-500">Total Paid</dt><dd class="text-xl font-bold text-green-600">$<%= Number(financial.total_paid || 0).toFixed(2) %></dd></div>
        <div><dt class="text-gray-500">Balance</dt><dd class="text-xl font-bold <%= (financial.balance || 0) > 0 ? 'text-red-600' : 'text-gray-800' %>">$<%= Number(financial.balance || 0).toFixed(2) %></dd></div>
      </dl>
      <% } else { %><p class="text-gray-400 text-sm">No financial data</p><% } %>
    </div>
  </div>

  <!-- Medical Alerts -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 mb-6">
    <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
      <h3 class="text-lg font-semibold text-gray-800">Medical Alerts</h3>
      <button onclick="document.getElementById('addMedicalForm').classList.toggle('hidden')" class="px-3 py-1 text-xs bg-orange-50 text-orange-600 rounded hover:bg-orange-100">+ Add</button>
    </div>
    <div id="addMedicalForm" class="hidden p-4 bg-orange-50 border-b">
      <form action="/patients/<%= patient.patient_id || patient.id %>/medical-history" method="POST" class="flex gap-3 items-end">
        <div class="flex-1">
          <label class="block text-xs text-gray-600 mb-1">Type</label>
          <select name="condition_type" class="w-full px-3 py-2 border rounded-lg text-sm" required>
            <option value="allergy">Allergy</option>
            <option value="chronic_disease">Chronic Disease</option>
            <option value="medication">Medication</option>
            <option value="surgery">Surgery</option>
          </select>
        </div>
        <div class="flex-[2]">
          <label class="block text-xs text-gray-600 mb-1">Description</label>
          <input type="text" name="description" class="w-full px-3 py-2 border rounded-lg text-sm" required>
        </div>
        <button class="px-4 py-2 bg-orange-500 text-white rounded-lg text-sm hover:bg-orange-600">Add</button>
      </form>
    </div>
    <div class="divide-y">
      <% medicalAlerts.forEach(function(m) { %>
        <div class="px-6 py-3 flex items-center gap-3">
          <span class="px-2 py-1 rounded text-xs font-medium
            <%= m.condition_type === 'allergy' ? 'bg-red-100 text-red-700' :
               m.condition_type === 'chronic_disease' ? 'bg-purple-100 text-purple-700' :
               m.condition_type === 'medication' ? 'bg-blue-100 text-blue-700' :
               'bg-gray-100 text-gray-700' %>"><%= m.condition_type %></span>
          <span class="text-sm"><%= m.description %></span>
        </div>
      <% }) %>
      <% if (medicalAlerts.length === 0) { %>
        <div class="px-6 py-4 text-gray-400 text-sm">No medical alerts recorded</div>
      <% } %>
    </div>
  </div>

  <!-- Treatment History -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200">
    <div class="px-6 py-4 border-b border-gray-200">
      <h3 class="text-lg font-semibold text-gray-800">Treatment History</h3>
      <p class="text-sm text-gray-500 mt-1">Data from <span class="sql-badge badge-view">VIEW</span> vw_TreatmentHistory</p>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Service</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Cost</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Teeth</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% treatments.forEach(function(t) { %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4"><%= t.visit_date ? new Date(t.visit_date).toLocaleDateString() : '-' %></td>
              <td class="px-6 py-4"><%= t.service_name || '-' %></td>
              <td class="px-6 py-4">$<%= Number(t.cost || 0).toFixed(2) %></td>
              <td class="px-6 py-4"><%= t.teeth_treated || t.teeth_info || '-' %></td>
              <td class="px-6 py-4">
                <span class="px-2 py-1 rounded-full text-xs font-medium
                  <%= t.treatment_status === 'completed' || t.status === 'completed' ? 'bg-green-100 text-green-700' :
                     t.treatment_status === 'in_progress' || t.status === 'in_progress' ? 'bg-yellow-100 text-yellow-700' :
                     'bg-gray-100 text-gray-700' %>"><%= t.treatment_status || t.status %></span>
              </td>
            </tr>
          <% }) %>
          <% if (treatments.length === 0) { %>
            <tr><td colspan="5" class="px-6 py-8 text-center text-gray-400">No treatments found</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <% } else { %>
    <div class="text-center py-12 text-gray-400">Patient not found</div>
  <% } %>
</div>
