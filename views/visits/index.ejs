<div>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Visits & Treatments</h1>
      <p class="text-sm text-gray-500 mt-1">Track patient visits and procedures</p>
    </div>
    <a href="/visits/new" class="px-4 py-2 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition text-sm font-medium">+ New Visit</a>
  </div>

  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50/80">
          <tr>
            <th class="px-6 py-3 text-left text-[11px] font-semibold text-gray-500 uppercase tracking-wider">ID</th>
            <th class="px-6 py-3 text-left text-[11px] font-semibold text-gray-500 uppercase tracking-wider">Patient</th>
            <th class="px-6 py-3 text-left text-[11px] font-semibold text-gray-500 uppercase tracking-wider">Dentist</th>
            <th class="px-6 py-3 text-left text-[11px] font-semibold text-gray-500 uppercase tracking-wider">Date</th>
            <th class="px-6 py-3 text-left text-[11px] font-semibold text-gray-500 uppercase tracking-wider">Complaint</th>
            <th class="px-6 py-3 text-left text-[11px] font-semibold text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-[11px] font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% visits.forEach(function(v) { %>
            <tr class="hover:bg-indigo-50/30 transition">
              <td class="px-6 py-4 text-gray-500"><%= v.id %></td>
              <td class="px-6 py-4 font-medium"><%= v.first_name %> <%= v.last_name %></td>
              <td class="px-6 py-4"><%= v.dentist_name %></td>
              <td class="px-6 py-4"><%= new Date(v.visit_date).toLocaleDateString() %></td>
              <td class="px-6 py-4 max-w-xs truncate"><%= v.chief_complaint || '-' %></td>
              <td class="px-6 py-4">
                <span class="px-2 py-1 rounded-lg text-xs font-medium
                  <%= v.status === 'completed' ? 'bg-emerald-50 text-emerald-700' : 'bg-amber-50 text-amber-700' %>"><%= v.status %></span>
              </td>
              <td class="px-6 py-4">
                <a href="/visits/<%= v.id %>" class="px-3 py-1 text-xs bg-indigo-50 text-indigo-600 rounded hover:bg-indigo-100">View</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
