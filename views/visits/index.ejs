<div>
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Visits & Treatments</h1>
    <a href="/visits/new" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition text-sm font-medium">+ New Visit</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">ID</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Patient</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Dentist</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Complaint</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% visits.forEach(function(v) { %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 text-gray-500"><%= v.id %></td>
              <td class="px-6 py-4 font-medium"><%= v.first_name %> <%= v.last_name %></td>
              <td class="px-6 py-4"><%= v.dentist_name %></td>
              <td class="px-6 py-4"><%= new Date(v.visit_date).toLocaleDateString() %></td>
              <td class="px-6 py-4 max-w-xs truncate"><%= v.chief_complaint || '-' %></td>
              <td class="px-6 py-4">
                <span class="px-2 py-1 rounded-full text-xs font-medium
                  <%= v.status === 'completed' ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700' %>"><%= v.status %></span>
              </td>
              <td class="px-6 py-4">
                <a href="/visits/<%= v.id %>" class="px-3 py-1 text-xs bg-blue-50 text-blue-600 rounded hover:bg-blue-100">View</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
