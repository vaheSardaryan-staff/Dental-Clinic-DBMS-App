<% const currentPath = typeof reqPath !== 'undefined' ? reqPath : '/'; %>
<aside class="fixed left-0 top-16 bottom-0 w-64 bg-gradient-to-b from-indigo-950 via-indigo-900 to-slate-900 text-gray-300 overflow-y-auto z-40">
  <div class="py-5">
    <div class="px-5 mb-2 text-[10px] font-bold text-indigo-400/60 uppercase tracking-widest">Main</div>
    <a href="/" class="sidebar-link flex items-center gap-3 px-5 py-2.5 text-sm hover:bg-white/[0.06] transition-all duration-150 mx-2 rounded-lg <%= currentPath === '/' ? 'active' : '' %>">
      <svg class="w-[18px] h-[18px] opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
      Dashboard
    </a>

    <div class="px-5 mt-6 mb-2 text-[10px] font-bold text-indigo-400/60 uppercase tracking-widest">Management</div>
    <a href="/patients" class="sidebar-link flex items-center gap-3 px-5 py-2.5 text-sm hover:bg-white/[0.06] transition-all duration-150 mx-2 rounded-lg <%= currentPath.startsWith('/patients') ? 'active' : '' %>">
      <svg class="w-[18px] h-[18px] opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      Patients
    </a>
    <a href="/users" class="sidebar-link flex items-center gap-3 px-5 py-2.5 text-sm hover:bg-white/[0.06] transition-all duration-150 mx-2 rounded-lg <%= currentPath.startsWith('/users') ? 'active' : '' %>">
      <svg class="w-[18px] h-[18px] opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
      Users & Staff
    </a>
    <a href="/services" class="sidebar-link flex items-center gap-3 px-5 py-2.5 text-sm hover:bg-white/[0.06] transition-all duration-150 mx-2 rounded-lg <%= currentPath.startsWith('/services') ? 'active' : '' %>">
      <svg class="w-[18px] h-[18px] opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
      Services
    </a>

    <div class="px-5 mt-6 mb-2 text-[10px] font-bold text-indigo-400/60 uppercase tracking-widest">Clinical</div>
    <a href="/appointments" class="sidebar-link flex items-center gap-3 px-5 py-2.5 text-sm hover:bg-white/[0.06] transition-all duration-150 mx-2 rounded-lg <%= currentPath.startsWith('/appointments') ? 'active' : '' %>">
      <svg class="w-[18px] h-[18px] opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      Appointments
    </a>
    <a href="/visits" class="sidebar-link flex items-center gap-3 px-5 py-2.5 text-sm hover:bg-white/[0.06] transition-all duration-150 mx-2 rounded-lg <%= currentPath.startsWith('/visits') ? 'active' : '' %>">
      <svg class="w-[18px] h-[18px] opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      Visits & Treatments
    </a>

    <div class="px-5 mt-6 mb-2 text-[10px] font-bold text-indigo-400/60 uppercase tracking-widest">Financial</div>
    <a href="/billing/invoices" class="sidebar-link flex items-center gap-3 px-5 py-2.5 text-sm hover:bg-white/[0.06] transition-all duration-150 mx-2 rounded-lg <%= currentPath.startsWith('/billing') ? 'active' : '' %>">
      <svg class="w-[18px] h-[18px] opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2z"/></svg>
      Billing
    </a>
    <a href="/reports" class="sidebar-link flex items-center gap-3 px-5 py-2.5 text-sm hover:bg-white/[0.06] transition-all duration-150 mx-2 rounded-lg <%= currentPath.startsWith('/reports') ? 'active' : '' %>">
      <svg class="w-[18px] h-[18px] opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
      Reports
    </a>

    <div class="px-5 mt-6 mb-2 text-[10px] font-bold text-indigo-400/60 uppercase tracking-widest">Database Showcase</div>
    <a href="/showcase/triggers" class="sidebar-link flex items-center gap-3 px-5 py-2.5 text-sm hover:bg-white/[0.06] transition-all duration-150 mx-2 rounded-lg <%= currentPath === '/showcase/triggers' ? 'active' : '' %>">
      <svg class="w-[18px] h-[18px] opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      Triggers
    </a>
    <a href="/showcase/indexes" class="sidebar-link flex items-center gap-3 px-5 py-2.5 text-sm hover:bg-white/[0.06] transition-all duration-150 mx-2 rounded-lg <%= currentPath === '/showcase/indexes' ? 'active' : '' %>">
      <svg class="w-[18px] h-[18px] opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/></svg>
      Indexes
    </a>
    <a href="/showcase/dcl" class="sidebar-link flex items-center gap-3 px-5 py-2.5 text-sm hover:bg-white/[0.06] transition-all duration-150 mx-2 rounded-lg <%= currentPath === '/showcase/dcl' ? 'active' : '' %>">
      <svg class="w-[18px] h-[18px] opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
      Access Control
    </a>
  </div>
</aside>
