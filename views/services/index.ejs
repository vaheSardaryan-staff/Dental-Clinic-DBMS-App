<div>
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Dental Services</h1>
    <a href="/services/new" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition text-sm font-medium">+ Add Service</a>
  </div>

  <!-- Category Filter -->
  <div class="flex gap-2 mb-4 flex-wrap">
    <a href="/services" class="px-3 py-1.5 rounded-lg text-sm font-medium <%= !selectedCategory ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' %>">All</a>
    <% categories.forEach(function(c) { %>
      <a href="/services?category=<%= c.category %>" class="px-3 py-1.5 rounded-lg text-sm font-medium capitalize <%= selectedCategory === c.category ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' %>"><%= c.category %></a>
    <% }) %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <% services.forEach(function(s) { %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
        <div class="flex items-start justify-between mb-3">
          <div>
            <h3 class="font-semibold text-gray-800"><%= s.name %></h3>
            <span class="px-2 py-0.5 rounded text-xs font-medium bg-blue-50 text-blue-600 capitalize"><%= s.category %></span>
          </div>
          <span class="text-lg font-bold text-green-600">$<%= Number(s.default_cost).toFixed(2) %></span>
        </div>
        <% if (s.duration_minutes) { %><p class="text-sm text-gray-500 mb-2"><%= s.duration_minutes %> min</p><% } %>
        <% if (s.description) { %><p class="text-sm text-gray-600 mb-3"><%= s.description %></p><% } %>
        <div class="flex gap-2 pt-3 border-t border-gray-100">
          <a href="/services/<%= s.id %>/edit" class="px-3 py-1 text-xs bg-gray-50 text-gray-600 rounded hover:bg-gray-100">Edit</a>
          <form action="/services/<%= s.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete?')">
            <button class="px-3 py-1 text-xs bg-red-50 text-red-600 rounded hover:bg-red-100">Delete</button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>
</div>
