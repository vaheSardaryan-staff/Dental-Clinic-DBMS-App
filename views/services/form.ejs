<div>
  <a href="/services" class="text-sm text-indigo-600 hover:underline">&larr; Back to Services</a>
  <h1 class="text-2xl font-bold text-gray-900 mt-2 mb-6"><%= service ? 'Edit' : 'New' %> Service</h1>

  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 max-w-2xl">
    <form action="<%= service ? '/services/' + service.id + '?_method=PUT' : '/services' %>" method="POST">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-gray-700 mb-1">Service Name *</label>
          <input type="text" name="name" value="<%= service ? service.name : '' %>" required class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Category *</label>
          <select name="category" required class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
            <% ['restorative','preventive','orthodontic','surgical','cosmetic','diagnostic'].forEach(function(c) { %>
              <option value="<%= c %>" <%= service && service.category === c ? 'selected' : '' %>><%= c.charAt(0).toUpperCase() + c.slice(1) %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Default Cost ($) *</label>
          <input type="number" step="0.01" name="default_cost" value="<%= service ? service.default_cost : '' %>" required class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Duration (minutes)</label>
          <input type="number" name="duration_minutes" value="<%= service ? (service.duration_minutes || '') : '' %>" class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
          <textarea name="description" rows="3" class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"><%= service ? (service.description || '') : '' %></textarea>
        </div>
      </div>
      <div class="mt-6 flex gap-3">
        <button type="submit" class="px-6 py-2 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition text-sm font-medium"><%= service ? 'Update' : 'Create' %></button>
        <a href="/services" class="px-6 py-2 bg-gray-100 text-gray-600 rounded-xl hover:bg-gray-200 transition text-sm">Cancel</a>
      </div>
    </form>
  </div>
</div>
