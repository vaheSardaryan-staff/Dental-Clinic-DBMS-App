<div>
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
    <p class="text-sm text-gray-500 mt-1">Overview of your dental clinic operations</p>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 card-hover">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Total Patients</p>
          <p class="text-3xl font-bold text-gray-900 mt-2"><%= stats.patients %></p>
        </div>
        <div class="w-12 h-12 bg-gradient-to-br from-indigo-50 to-violet-50 rounded-2xl flex items-center justify-center">
          <svg class="w-6 h-6 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
      </div>
    </div>
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 card-hover">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Appointments (This Month)</p>
          <p class="text-3xl font-bold text-gray-900 mt-2"><%= stats.appointments %></p>
        </div>
        <div class="w-12 h-12 bg-gradient-to-br from-emerald-50 to-teal-50 rounded-2xl flex items-center justify-center">
          <svg class="w-6 h-6 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        </div>
      </div>
    </div>
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 card-hover">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Revenue (This Month)</p>
          <p class="text-3xl font-bold text-gray-900 mt-2"><%= Number(stats.revenue).toLocaleString('en-US') %> <span class="text-base font-medium text-gray-400">AMD</span></p>
        </div>
        <div class="w-12 h-12 bg-gradient-to-br from-violet-50 to-purple-50 rounded-2xl flex items-center justify-center">
          <svg class="w-6 h-6 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
      </div>
    </div>
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 card-hover">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Overdue Invoices</p>
          <p class="text-3xl font-bold <%= stats.overdue > 0 ? 'text-rose-600' : 'text-gray-900' %> mt-2"><%= stats.overdue %></p>
        </div>
        <div class="w-12 h-12 bg-gradient-to-br from-rose-50 to-red-50 rounded-2xl flex items-center justify-center">
          <svg class="w-6 h-6 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Charts Row -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
      <h3 class="text-base font-semibold text-gray-900 mb-4">Revenue by Dentist</h3>
      <canvas id="revenueByDentistChart" height="200"></canvas>
    </div>
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
      <h3 class="text-base font-semibold text-gray-900 mb-4">Monthly Revenue Trend</h3>
      <canvas id="monthlyRevenueChart" height="200"></canvas>
    </div>
  </div>

  <!-- Recent Appointments -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-5 border-b border-gray-100">
      <h3 class="text-base font-semibold text-gray-900">Recent Appointments</h3>
      <p class="text-xs text-gray-400 mt-1">Data from <span class="sql-badge badge-view">VIEW</span> vw_AppointmentDetails</p>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50/80">
          <tr>
            <th class="px-6 py-3 text-left text-[11px] font-semibold text-gray-500 uppercase tracking-wider">Patient</th>
            <th class="px-6 py-3 text-left text-[11px] font-semibold text-gray-500 uppercase tracking-wider">Dentist</th>
            <th class="px-6 py-3 text-left text-[11px] font-semibold text-gray-500 uppercase tracking-wider">Service</th>
            <th class="px-6 py-3 text-left text-[11px] font-semibold text-gray-500 uppercase tracking-wider">Date</th>
            <th class="px-6 py-3 text-left text-[11px] font-semibold text-gray-500 uppercase tracking-wider">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% recentAppointments.forEach(function(a) { %>
            <tr class="hover:bg-indigo-50/30 transition">
              <td class="px-6 py-4 font-medium text-gray-900"><%= a.patient_name || (a.first_name + ' ' + a.last_name) %></td>
              <td class="px-6 py-4 text-gray-600"><%= a.dentist_name || a.full_name %></td>
              <td class="px-6 py-4 text-gray-600"><%= a.service_name || a.title || '-' %></td>
              <td class="px-6 py-4 text-gray-500"><%= a.start_time ? new Date(a.start_time).toLocaleDateString() : '-' %></td>
              <td class="px-6 py-4">
                <span class="px-2.5 py-1 rounded-lg text-xs font-semibold
                  <%= a.status === 'completed' ? 'bg-emerald-50 text-emerald-700' :
                     a.status === 'scheduled' ? 'bg-indigo-50 text-indigo-700' :
                     a.status === 'cancelled' ? 'bg-rose-50 text-rose-700' :
                     'bg-amber-50 text-amber-700' %>">
                  <%= a.status %>
                </span>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const dentistData = <%- JSON.stringify(revenueByDentist) %>;
  if (dentistData.length > 0) {
    new Chart(document.getElementById('revenueByDentistChart'), {
      type: 'bar',
      data: {
        labels: dentistData.map(d => d.dentist_name || d.full_name || 'Unknown'),
        datasets: [{
          label: 'Total Billed',
          data: dentistData.map(d => d.total_billed || d.total_amount || 0),
          backgroundColor: '#6366f1',
          borderRadius: 8,
        }, {
          label: 'Collected',
          data: dentistData.map(d => d.total_collected || d.amount_collected || 0),
          backgroundColor: '#a78bfa',
          borderRadius: 8,
        }]
      },
      options: { responsive: true, scales: { y: { beginAtZero: true, grid: { color: '#f1f5f9' } }, x: { grid: { display: false } } }, plugins: { legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20 } } } }
    });
  }

  const monthlyData = <%- JSON.stringify(monthlyRevenue) %>;
  if (monthlyData.length > 0) {
    new Chart(document.getElementById('monthlyRevenueChart'), {
      type: 'line',
      data: {
        labels: monthlyData.map(d => d.revenue_month || d.month || 'Unknown'),
        datasets: [{
          label: 'Revenue',
          data: monthlyData.map(d => d.total_revenue || d.total || 0),
          borderColor: '#8b5cf6',
          backgroundColor: 'rgba(139,92,246,0.08)',
          fill: true,
          tension: 0.4,
          pointRadius: 5,
          pointBackgroundColor: '#8b5cf6',
          pointBorderColor: '#fff',
          pointBorderWidth: 2,
        }]
      },
      options: { responsive: true, scales: { y: { beginAtZero: true, grid: { color: '#f1f5f9' } }, x: { grid: { display: false } } }, plugins: { legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20 } } } }
    });
  }
});
</script>
