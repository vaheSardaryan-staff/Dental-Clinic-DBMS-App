<div>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Invoices</h1>
      <p class="text-sm text-gray-500 mt-1">Generate and manage patient invoices</p>
    </div>
  </div>

  <!-- Generate Invoice -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6">
    <h3 class="text-lg font-semibold text-gray-800 mb-2">Generate Invoice</h3>
    <p class="text-sm text-gray-500 mb-4">Uses <span class="sql-badge badge-procedure">STORED PROCEDURE</span> sp_GenerateInvoice + <span class="sql-badge badge-trigger">TRIGGER</span> trg_AutoSetDueDate</p>
    <form action="/billing/invoices/generate" method="POST" class="flex gap-3 items-end flex-wrap">
      <div>
        <label class="block text-xs text-gray-600 mb-1">Visit (without invoice)</label>
        <select name="visit_id" required class="px-3 py-2 border border-gray-200 rounded-xl text-sm">
          <option value="">Select visit...</option>
          <% visits.forEach(function(v) { %>
            <option value="<%= v.id %>"><%= v.first_name %> <%= v.last_name %> - <%= new Date(v.visit_date).toLocaleDateString() %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="block text-xs text-gray-600 mb-1">Discount ($)</label>
        <input type="number" step="0.01" name="discount" value="0" class="px-3 py-2 border border-gray-200 rounded-xl text-sm w-28">
      </div>
      <button class="px-4 py-2 bg-emerald-600 text-white rounded-xl text-sm hover:bg-emerald-700">Generate</button>
    </form>
  </div>

  <!-- Overdue Invoices -->
  <% if (overdue.length > 0) { %>
  <div class="bg-rose-50 rounded-2xl border border-rose-200 mb-6">
    <div class="px-6 py-5 border-b border-rose-200">
      <h3 class="text-lg font-semibold text-rose-800">Overdue Invoices</h3>
      <p class="text-sm text-rose-600 mt-1">Data from <span class="sql-badge badge-view">VIEW</span> vw_OverdueInvoices</p>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-rose-100/50">
          <tr>
            <th class="px-6 py-3 text-left text-[11px] font-semibold text-rose-700 uppercase tracking-wider">Invoice #</th>
            <th class="px-6 py-3 text-left text-[11px] font-semibold text-rose-700 uppercase tracking-wider">Patient</th>
            <th class="px-6 py-3 text-left text-[11px] font-semibold text-rose-700 uppercase tracking-wider">Amount</th>
            <th class="px-6 py-3 text-left text-[11px] font-semibold text-rose-700 uppercase tracking-wider">Days Overdue</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-rose-200">
          <% overdue.forEach(function(o) { %>
            <tr>
              <td class="px-6 py-3 text-rose-800 font-medium">#<%= o.invoice_id || o.id %></td>
              <td class="px-6 py-3"><%= o.patient_name || (o.first_name + ' ' + o.last_name) %></td>
              <td class="px-6 py-3 font-medium">$<%= Number(o.total_amount || o.amount_due || 0).toFixed(2) %></td>
              <td class="px-6 py-3"><span class="px-2 py-1 bg-rose-200 text-rose-800 rounded-lg text-xs font-bold"><%= o.days_overdue %> days</span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>

  <!-- All Invoices -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-5 border-b border-gray-100">
      <h3 class="text-lg font-semibold text-gray-800">All Invoices</h3>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50/80">
          <tr>
            <th class="px-6 py-3 text-left text-[11px] font-semibold text-gray-500 uppercase tracking-wider">ID</th>
            <th class="px-6 py-3 text-left text-[11px] font-semibold text-gray-500 uppercase tracking-wider">Patient</th>
            <th class="px-6 py-3 text-left text-[11px] font-semibold text-gray-500 uppercase tracking-wider">Total</th>
            <th class="px-6 py-3 text-left text-[11px] font-semibold text-gray-500 uppercase tracking-wider">Discount</th>
            <th class="px-6 py-3 text-left text-[11px] font-semibold text-gray-500 uppercase tracking-wider">Paid</th>
            <th class="px-6 py-3 text-left text-[11px] font-semibold text-gray-500 uppercase tracking-wider">Due Date</th>
            <th class="px-6 py-3 text-left text-[11px] font-semibold text-gray-500 uppercase tracking-wider">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% invoices.forEach(function(i) { %>
            <tr class="hover:bg-indigo-50/30 transition">
              <td class="px-6 py-4 text-gray-500">#<%= i.id %></td>
              <td class="px-6 py-4 font-medium"><%= i.first_name %> <%= i.last_name %></td>
              <td class="px-6 py-4">$<%= Number(i.total_amount).toFixed(2) %></td>
              <td class="px-6 py-4">$<%= Number(i.discount || 0).toFixed(2) %></td>
              <td class="px-6 py-4 text-emerald-600 font-medium">$<%= Number(i.total_paid || 0).toFixed(2) %></td>
              <td class="px-6 py-4"><%= i.due_date ? new Date(i.due_date).toLocaleDateString() : '-' %></td>
              <td class="px-6 py-4">
                <span class="px-2 py-1 rounded-lg text-xs font-medium
                  <%= i.status === 'paid' ? 'bg-emerald-50 text-emerald-700' :
                     i.status === 'issued' ? 'bg-indigo-50 text-indigo-700' :
                     i.status === 'overdue' ? 'bg-rose-50 text-rose-700' :
                     i.status === 'draft' ? 'bg-gray-100 text-gray-700' :
                     'bg-amber-50 text-amber-700' %>"><%= i.status %></span>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
