<div>
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Invoices</h1>
  </div>

  <!-- Generate Invoice -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
    <h3 class="text-lg font-semibold text-gray-800 mb-2">Generate Invoice</h3>
    <p class="text-sm text-gray-500 mb-4">Uses <span class="sql-badge badge-procedure">STORED PROCEDURE</span> sp_GenerateInvoice + <span class="sql-badge badge-trigger">TRIGGER</span> trg_AutoSetDueDate</p>
    <form action="/billing/invoices/generate" method="POST" class="flex gap-3 items-end flex-wrap">
      <div>
        <label class="block text-xs text-gray-600 mb-1">Visit (without invoice)</label>
        <select name="visit_id" required class="px-3 py-2 border rounded-lg text-sm">
          <option value="">Select visit...</option>
          <% visits.forEach(function(v) { %>
            <option value="<%= v.id %>"><%= v.first_name %> <%= v.last_name %> - <%= new Date(v.visit_date).toLocaleDateString() %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="block text-xs text-gray-600 mb-1">Discount ($)</label>
        <input type="number" step="0.01" name="discount" value="0" class="px-3 py-2 border rounded-lg text-sm w-28">
      </div>
      <button class="px-4 py-2 bg-green-600 text-white rounded-lg text-sm hover:bg-green-700">Generate</button>
    </form>
  </div>

  <!-- Overdue Invoices -->
  <% if (overdue.length > 0) { %>
  <div class="bg-red-50 rounded-xl border border-red-200 mb-6">
    <div class="px-6 py-4 border-b border-red-200">
      <h3 class="text-lg font-semibold text-red-800">Overdue Invoices</h3>
      <p class="text-sm text-red-600 mt-1">Data from <span class="sql-badge badge-view">VIEW</span> vw_OverdueInvoices</p>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-red-100/50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-red-700 uppercase">Invoice #</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-red-700 uppercase">Patient</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-red-700 uppercase">Amount</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-red-700 uppercase">Days Overdue</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-red-200">
          <% overdue.forEach(function(o) { %>
            <tr>
              <td class="px-6 py-3 text-red-800 font-medium">#<%= o.invoice_id || o.id %></td>
              <td class="px-6 py-3"><%= o.patient_name || (o.first_name + ' ' + o.last_name) %></td>
              <td class="px-6 py-3 font-medium">$<%= Number(o.total_amount || o.amount_due || 0).toFixed(2) %></td>
              <td class="px-6 py-3"><span class="px-2 py-1 bg-red-200 text-red-800 rounded-full text-xs font-bold"><%= o.days_overdue %> days</span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>

  <!-- All Invoices -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h3 class="text-lg font-semibold text-gray-800">All Invoices</h3>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">ID</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Patient</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Total</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Discount</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Paid</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Due Date</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% invoices.forEach(function(i) { %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 text-gray-500">#<%= i.id %></td>
              <td class="px-6 py-4 font-medium"><%= i.first_name %> <%= i.last_name %></td>
              <td class="px-6 py-4">$<%= Number(i.total_amount).toFixed(2) %></td>
              <td class="px-6 py-4">$<%= Number(i.discount || 0).toFixed(2) %></td>
              <td class="px-6 py-4 text-green-600 font-medium">$<%= Number(i.total_paid || 0).toFixed(2) %></td>
              <td class="px-6 py-4"><%= i.due_date ? new Date(i.due_date).toLocaleDateString() : '-' %></td>
              <td class="px-6 py-4">
                <span class="px-2 py-1 rounded-full text-xs font-medium
                  <%= i.status === 'paid' ? 'bg-green-100 text-green-700' :
                     i.status === 'issued' ? 'bg-blue-100 text-blue-700' :
                     i.status === 'overdue' ? 'bg-red-100 text-red-700' :
                     i.status === 'draft' ? 'bg-gray-100 text-gray-700' :
                     'bg-yellow-100 text-yellow-700' %>"><%= i.status %></span>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
